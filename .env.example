# Copy this file to .env and fill in values for local development.
# Never commit .env — it is gitignored.

# PostgreSQL connection string (matches docker-compose.yaml defaults)
DATABASE_URL=postgresql://argus:argus@localhost:5433/argus

# API server port
PORT=5000

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# --- Dashboard only (apps/dashboard) ---
# Both vars are required; vite.config.ts throws at startup if either is missing.
# PORT for the dashboard is set separately when starting the dashboard dev server.
BASE_PATH=/
API_PORT=5000
